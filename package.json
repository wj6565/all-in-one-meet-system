    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.5",
    "formidable": "^3.5.4",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^8.0.5",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
