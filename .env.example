# =============================================
# ALL IN ONE MEET SYSTEM - 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요
# cp .env.example .env
# =============================================

# DB (SQLite - 경로만 변경하면 됨)
DATABASE_URL="file:/home/user/webapp/dev.db"

# NextAuth
NEXTAUTH_SECRET="integrated-meet-system-secret-2026"
# ↓ 아래 URL을 현재 sandbox URL로 변경하세요
NEXTAUTH_URL="https://3000-XXXXXX-8f57ffe2.sandbox.novita.ai"

# =============================================
# STT / 요약 / 메일 Provider 설정
# mock  = 테스트용 (실제 API 호출 안함)
# openai = 실제 OpenAI API 사용
# =============================================
STT_PROVIDER=mock
SUMMARY_PROVIDER=mock
EMAIL_PROVIDER=mock

# OpenAI API Key (STT_PROVIDER=openai 또는 SUMMARY_PROVIDER=openai 시 필요)
# 1. https://platform.openai.com 접속
# 2. API Keys 메뉴 → Create new secret key
# 3. 아래 주석 해제 후 키 붙여넣기
# OPENAI_API_KEY=sk-proj-여기에붙여넣기
# OPENAI_MODEL=gpt-4o-mini
